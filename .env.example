# Server Configuration
NODE_ENV=production
PORT=3001
LOG_LEVEL=info

# Local PostgREST API (database)
ELPASS_API_URL=http://postgrest:3000

# Local Photo Server
PIC_SERVER=http://picserver:9000/pic

# Timeouts (milliseconds)
TERMINAL_REQUEST_TIMEOUT=30000
RETRY_MAX_ATTEMPTS=3
RETRY_DELAY_MS=1000

# PostgreSQL (used by docker-compose)
POSTGRES_DB=elpass
POSTGRES_USER=elpass
POSTGRES_PASSWORD=<your-secure-password>

# PostgREST JWT Secret (used to sign ELPASS_TOKEN)
PGRST_JWT_SECRET=<your-jwt-secret-min-32-chars>
